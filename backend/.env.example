# ── Server ──────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ainews
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/ainews

# ── AI ───────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── News APIs (use at least one) ─────────────────────
# Option 1: NewsAPI.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Option 2: GNews API (free tier: 100 req/day)
GNEWS_API_KEY=your_gnews_key_here

# Option 3: The Guardian API (free, generous limits)
GUARDIAN_API_KEY=your_guardian_key_here

# Which provider to use: "newsapi" | "gnews" | "guardian"
NEWS_PROVIDER=newsapi

# ── Cache ────────────────────────────────────────────
# Seconds to cache news feed (avoid hammering the API)
NEWS_CACHE_TTL=300

# ── CORS ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
